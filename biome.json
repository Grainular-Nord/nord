{
    "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
    "vcs": { "enabled": false, "clientKind": "git", "useIgnoreFile": false },
    "files": { "ignoreUnknown": false, "includes": ["**"] },
    "formatter": {
        "enabled": true,
        "useEditorconfig": true,
        "formatWithErrors": false,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineEnding": "lf",
        "lineWidth": 120,
        "attributePosition": "auto",
        "bracketSpacing": true,
        "includes": ["**", "!**/license.md", "!**/*.json", "!**/node_modules", "!**/.idea/**/*"]
    },
    "assist": { "actions": { "source": { "organizeImports": "on" } } },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "suspicious": {
                "noConfusingVoidType": "off"
            },
            "style": {
                "noInferrableTypes": "off",
                "noRestrictedImports": {
                    "level": "error",
                    "options": {
                        "paths": {
                            "*/dist/*": "Do not import from dist/ within src/. Import from the source file directly."
                        }
                    }
                }
            },
            "correctness": {}
        }
    },
    "javascript": {
        "formatter": {
            "quoteProperties": "asNeeded",
            "trailingCommas": "all",
            "semicolons": "always",
            "arrowParentheses": "always",
            "bracketSameLine": false,
            "quoteStyle": "single",
            "attributePosition": "auto",
            "bracketSpacing": true
        }
    },
    "css": {
        "parser": {
            "tailwindDirectives": true
        }
    },
    "overrides": [{ "includes": ["**/*.html"] }]
}
