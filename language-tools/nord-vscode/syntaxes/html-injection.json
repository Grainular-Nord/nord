{
  "scopeName": "inline.html.injection",
  "injectionSelector": "L:source.ts -comment -string, L:source.js -comment -string, L:source.tsx -comment -string, L:source.jsx -comment -string",
  "patterns": [
    {
      "include": "#html-tagged-template"
    },
    {
      "include": "#css-tagged-template"
    }
  ],
  "repository": {
    "html-tagged-template": {
      "begin": "(html)(`)",
      "beginCaptures": {
        "1": { "name": "entity.name.function.tagged-template.ts" },
        "2": { "name": "string.template.ts" }
      },
      "end": "`",
      "endCaptures": {
        "0": { "name": "string.template.ts" }
      },
      "patterns": [
        {
          "include": "#interpolation"
        },
        {
          "include": "text.html.basic"
        }
      ]
    },
    "css-tagged-template": {
      "begin": "(css)(`)",
      "beginCaptures": {
        "1": { "name": "entity.name.function.tagged-template.ts" },
        "2": { "name": "string.template.ts" }
      },
      "end": "`",
      "endCaptures": {
        "0": { "name": "string.template.ts" }
      },
      "patterns": [
        {
          "include": "#interpolation"
        },
        {
          "include": "source.css"
        }
      ]
    },
    "interpolation": {
      "name": "meta.embedded.expression.nord",
      "begin": "\\$\\{",
      "beginCaptures": {
        "0": { "name": "punctuation.section.embedded.begin.ts" }
      },
      "end": "\\}",
      "endCaptures": {
        "0": { "name": "punctuation.section.embedded.end.ts" }
      },
      "patterns": [
        { "include": "source.ts" },
        { "include": "source.tsx" },
        { "include": "source.js" },
        { "include": "source.jsx" }
      ]
    }
  }
}