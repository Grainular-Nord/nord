{
    "name": "@grainular/repository",
    "type": "module",
    "private": true,
    "packageManager": "bun@1.1.18",
    "devDependencies": {
        "@biomejs/biome": "1.9.4",
        "@changesets/changelog-github": "^0.5.0",
        "@changesets/cli": "^2.27.9",
        "@commitlint/cli": "^19.3.0",
        "@commitlint/config-conventional": "^19.2.2",
        "@types/bun": "^1.2.16",
        "alex": "^11.0.1",
        "husky": "^9.0.11",
        "prettier": "^3.3.2",
        "turbo": "^2.0.6",
        "typescript": "^5.5.3",
        "lefthook": "^1.11.9"
    },
    "peerDependencies": {
        "typescript": "^5.0.0"
    },
    "scripts": {
        "preci": "rm -rf node_modules",
        "ci": "bun install --frozen-lockfile",
        "setup": "husky",
        "lint:ts": "biome lint",
        "lint:md": "alex",
        "format": "biome format --write",
        "dev": "turbo dev",
        "build": "turbo build",
        "test": "turbo test"
    },
    "workspaces": [
        "packages/@grainular/*",
        "packages/@repository/*"
    ],
    "dependencies": {
        "@grainular/repository": "."
    }
}
