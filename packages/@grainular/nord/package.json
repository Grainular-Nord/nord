{
    "name": "@grainular/nord",
    "version": "2.0.0-next.4",
    "description": "A lightweight, dependency-free, TypeScript-first reactive UI framework.",
    "type": "module",
    "packageManager": "bun@1.2.7",
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.js",
    "types": "./dist/types/index.d.cts",
    "exports": {
        ".": {
            "types": "./dist/types/index.d.cts",
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js"
        }
    },
    "unpkg": "./dist/browser/index.js",
    "devDependencies": {
        "@grainular/grains": "workspace:*",
        "@repository/builder": "workspace:*",
        "@repository/config": "workspace:*",
        "@types/bun": "latest",
        "@types/jsdom": "^28.0.3",
        "jsdom": "^29.1.1",
        "tsup": "^8.5.1",
        "typescript": "^6.0.3"
    },
    "scripts": {
        "dev": "bunx tsup --watch",
        "build": "bunx tsup",
        "prepublishOnly": "bunx tsup",
        "test": "bun test",
        "test:cov": "bun test --coverage"
    },
    "sideEffects": false,
    "publishConfig": {
        "access": "public",
        "tag": "next"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/grainular/nord.git"
    }
}
