{
    "name": "@grainular/nord",
    "version": "2.0.0",
    "type": "module",
    "packageManager": "bun@1.2.7",
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.js",
    "types": "./dist/types/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/types/index.d.ts",
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js"
        }
    },
    "unpkg": "./dist/browser/index.js",
    "devDependencies": {
        "@repository/builder": "workspace:*",
        "@repository/config": "workspace:*",
        "@grainular/grains": "workspace:*",
        "@types/bun": "latest",
        "@types/jsdom": "^27.0.0",
        "jsdom": "^27.4.0",
        "typescript": "^5.0.0"
    },
    "scripts": {
        "dev": "bun run .build.ts --watch",
        "build": "bun run .build.ts",
        "test": "bun test",
        "test:cov": "bun test --coverage",
        "prepublishOnly": "bun run build"
    },
    "sideEffects": false,
    "publishConfig": {
        "access": "public"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/grainular/core.git"
    }
}
